&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    p(v&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;_&lt;/span&gt;i=1|&lt;span style=&#34;color:#ff79c6&#34;&gt;\mathbf&lt;/span&gt;&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;{&lt;/span&gt;h&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;}&lt;/span&gt;) &lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;&amp;amp;&lt;/span&gt; = &lt;span style=&#34;color:#ff79c6&#34;&gt;\sigma\left&lt;/span&gt;(&lt;span style=&#34;color:#ff79c6&#34;&gt;\sum&lt;/span&gt;&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;_&lt;/span&gt;j w&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;_{&lt;/span&gt;ij&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;}&lt;/span&gt;h&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;_&lt;/span&gt;j + b&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;_&lt;/span&gt;i&lt;span style=&#34;color:#ff79c6&#34;&gt;\right&lt;/span&gt;) &lt;span style=&#34;color:#ff79c6&#34;&gt;\\&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    p(h&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;_&lt;/span&gt;j=1|&lt;span style=&#34;color:#ff79c6&#34;&gt;\mathbf&lt;/span&gt;&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;{&lt;/span&gt;v&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;}&lt;/span&gt;) &lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;&amp;amp;&lt;/span&gt; = &lt;span style=&#34;color:#ff79c6&#34;&gt;\sigma\left&lt;/span&gt;(&lt;span style=&#34;color:#ff79c6&#34;&gt;\sum&lt;/span&gt;&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;_&lt;/span&gt;i w&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;_{&lt;/span&gt;ij&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;}&lt;/span&gt;v&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;_&lt;/span&gt;i + c&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;_&lt;/span&gt;j&lt;span style=&#34;color:#ff79c6&#34;&gt;\right&lt;/span&gt;)
&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#ff79c6&#34;&gt;\end&lt;/span&gt;&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;{&lt;/span&gt;align&lt;span style=&#34;color:#8be9fd;font-style:italic&#34;&gt;}&lt;/span&gt;
